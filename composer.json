{
    "name": "alfinprdht/query-pulse",
    "description": "Laravel package for query pulse",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Alfinprdht\\QueryPulse\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Alfinprdht\\QueryPulse\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Alfinprdht\\QueryPulse\\QueryPulseServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
